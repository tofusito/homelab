# OpenClaw stack environment variables
# Copia este fichero a .env y rellena los valores

# Token interno gateway <-> cli (genera uno aleatorio, p.ej: openssl rand -hex 32)
OPENCLAW_GATEWAY_TOKEN=

# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

OPENCLAW_DATA_DIR=/your/openclaw/data/dir

# Timezone
TZ=Europe/Madrid
